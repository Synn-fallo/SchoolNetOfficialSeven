import { useState, useCallback } from 'react';
import { supabase } from '@supabase/supabase-js';
import { 
  Parent, 
  ParentEleve, 
  TypeLienParente, 
  CreateParentData,
  ParentWithDetails,
  ParentVerificationResult,
  ParentExistsResult
} from '@/types/parents.types';

/**
 * Hook de gestion multi-parents (Version 2)
 * Utilise les nouvelles tables parents et parent_eleve
 */
export function useParentsV2() {
  const [loading, setLoading] = useState(false);
  const [verifying, setVerifying] = useState(false);
  const [linking, setLinking] = useState(false);

  /**
   * Vérifie si un parent existe (par téléphone ou email)
   */
  const verifierParent = useCallback(async (
    telephone?: string,
    email?: string
  ): Promise<ParentExistsResult> => {
    if (!telephone && !email) {
      return { exists: false };
    }

    setVerifying(true);
    try {
      let query = supabase.from('parents').select(`
          *,
          parent_eleve!inner (
            eleve_id,
            type_lien,
            eleves:eleve_id (
              id,
              user_id,
              profiles:user_id (prenom, nom)
            )
          )
        `);

      if (telephone) {
        query = query.eq('telephone', telephone);
      } else if (email) {
        query = query.eq('email_personnel', email);
      }

      const { data, error } = await query.maybeSingle();

      if (error || !data) {
        return { exists: false };
      }

      // Générer les initiales des enfants (3 lettres)
      const getInitiale = (prenom: string) => {
        if (!prenom) return '';
        return prenom.substring(0, 3).toUpperCase();
      };

      const enfants = (data.parent_eleve || []).map((pe: any) => {
        const enfant = pe.eleves;
        const prenom = enfant?.profiles?.prenom || '';
        const nom = enfant?.profiles?.nom || '';
        return {
          id: enfant?.id,
          prenom: prenom,
          initiale_3_lettres: getInitiale(prenom),
          nom_initial: nom ? nom.charAt(0).toUpperCase() : '',
          affichage: `${getInitiale(prenom)}. ${nom ? nom.charAt(0).toUpperCase() : ''}.`
        };
      });

      return {
        exists: true,
        parent: {
          id: data.id,
          user_id: data.user_id,
          nom: data.nom,
          prenom: data.prenom,
          telephone: data.telephone,
          email_snet: data.email_snet,
          email_personnel: data.email_personnel,
          premiere_connexion: data.premiere_connexion,
          is_active: data.is_active,
          created_at: data.created_at,
          updated_at: data.updated_at,
        },
        enfants_initiales: enfants,
        nb_enfants: enfants.length,
      };
    } catch (error) {
      console.error('Error verifying parent:', error);
      return { exists: false };
    } finally {
      setVerifying(false);
    }
  }, []);

  /**
   * Confirme le parent par le prénom d'un enfant
   */
  const confirmerParentParEnfant = useCallback(async (
    parentId: string,
    prenomEnfant: string
  ): Promise<ParentVerificationResult> => {
    setVerifying(true);
    try {
      const { data, error } = await supabase
        .from('parent_eleve')
        .select(`
          eleve_id,
          eleves:eleve_id (
            user_id,
            profiles:user_id (prenom)
          )
        `)
        .eq('parent_id', parentId);

      if (error) {
        return { success: false, message: 'Erreur lors de la vérification' };
      }

      const prenomRecherche = prenomEnfant.trim().toLowerCase();
      const enfantTrouve = data?.some(item => {
        const prenom = item.eleves?.profiles?.prenom?.toLowerCase() || '';
        return prenom === prenomRecherche || prenom.startsWith(prenomRecherche);
      });

      if (enfantTrouve) {
        return { success: true, parent_id: parentId };
      } else {
        return { success: false, message: 'Prénom non trouvé parmi les enfants associés' };
      }
    } catch (error) {
      console.error('Error confirming parent by child:', error);
      return { success: false, message: 'Erreur lors de la vérification' };
    } finally {
      setVerifying(false);
    }
  }, []);

  /**
   * Crée un nouveau parent
   */
  const creerNouveauParent = useCallback(async (
    data: CreateParentData
  ): Promise<{ success: boolean; parent?: Parent; error?: string; motDePasseTemp?: string }> => {
    setLoading(true);
    try {
      // Normaliser les noms
      const nom = data.nom.toUpperCase();
      const prenom = data.prenom;

      // Générer l'email SNET
      const normalize = (str: string) => {
        return str
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/[^a-z0-9.-]/g, '')
          .replace(/\.+/g, '.')
          .replace(/^\.|\.$/g, '');
      };
      let emailSnet = `${normalize(prenom)}.${normalize(nom)}@snet.bj`;
      
      // Vérifier l'unicité de l'email SNET
      let suffixe = 1;
      let exists = true;
      while (exists && suffixe < 100) {
        const { data: check } = await supabase
          .from('parents')
          .select('id')
          .eq('email_snet', emailSnet)
          .maybeSingle();
        if (!check) {
          exists = false;
        } else {
          emailSnet = `${normalize(prenom)}.${normalize(nom)}.${suffixe}@snet.bj`;
          suffixe++;
        }
      }

      // Générer mot de passe temporaire
      const chiffres = Math.floor(1000 + Math.random() * 9000);
      const motDePasseTemp = `Parent${prenom}${chiffres}`;

      // Créer l'utilisateur auth
      const { data: authUser, error: authError } = await supabase.auth.admin.createUser({
        email: emailSnet,
        password: motDePasseTemp,
        email_confirm: true,
        user_metadata: { nom, prenom, role: 'parent', telephone: data.telephone },
      });

      if (authError) {
        return { success: false, error: authError.message };
      }

      // Créer l'entrée parents
      const { data: parentData, error: parentError } = await supabase
        .from('parents')
        .insert({
          user_id: authUser.user.id,
          nom: nom,
          prenom: prenom,
          telephone: data.telephone,
          email_snet: emailSnet,
          email_personnel: data.email_personnel || null,
          mot_de_passe_temp: motDePasseTemp,
          premiere_connexion: true,
          is_active: true,
        })
        .select()
        .single();

      if (parentError) {
        await supabase.auth.admin.deleteUser(authUser.user.id);
        return { success: false, error: parentError.message };
      }

      return {
        success: true,
        parent: parentData as Parent,
        motDePasseTemp,
      };
    } catch (error) {
      console.error('Error creating parent:', error);
      return { success: false, error: 'Erreur lors de la création du parent' };
    } finally {
      setLoading(false);
    }
  }, []);

  /**
   * Lie un parent à un élève
   */
  const lierParent = useCallback(async (
    parentId: string,
    eleveId: string,
    typeLien: TypeLienParente,
    estPrincipal: boolean = false
  ): Promise<{ success: boolean; error?: string }> => {
    setLinking(true);
    try {
      const { error } = await supabase
        .from('parent_eleve')
        .insert({
          parent_id: parentId,
          eleve_id: eleveId,
          type_lien: typeLien,
          est_principal: estPrincipal,
        });

      if (error) throw error;
      return { success: true };
    } catch (error) {
      console.error('Error linking parent:', error);
      return { success: false, error: 'Impossible de lier le parent' };
    } finally {
      setLinking(false);
    }
  }, []);

  /**
   * Récupère tous les parents d'un élève
   */
  const getParentsDeLEleve = useCallback(async (eleveId: string): Promise<ParentWithDetails[]> => {
    setLoading(true);
    try {
      const { data, error } = await supabase
        .from('parent_eleve')
        .select(`
          id,
          parent_id,
          type_lien,
          est_principal,
          est_contact_urgence,
          autorisations,
          parents:parent_id (*)
        `)
        .eq('eleve_id', eleveId);

      if (error) throw error;

      return (data || []).map(item => ({
        ...(item.parents as Parent),
        type_lien: item.type_lien as TypeLienParente,
        est_principal: item.est_principal,
        est_contact_urgence: item.est_contact_urgence,
      }));
    } catch (error) {
      console.error('Error getting parents:', error);
      return [];
    } finally {
      setLoading(false);
    }
  }, []);

  /**
   * Met à jour le lien parent-élève
   */
  const mettreAJourLien = useCallback(async (
    parentEleveId: string,
    updates: { est_principal?: boolean; est_contact_urgence?: boolean; autorisations?: any }
  ): Promise<{ success: boolean; error?: string }> => {
    try {
      const { error } = await supabase
        .from('parent_eleve')
        .update(updates)
        .eq('id', parentEleveId);

      if (error) throw error;
      return { success: true };
    } catch (error) {
      console.error('Error updating parent-eleve link:', error);
      return { success: false, error: 'Impossible de mettre à jour le lien' };
    }
  }, []);

  /**
   * Supprime le lien parent-élève
   */
  const supprimerLien = useCallback(async (
    parentId: string,
    eleveId: string
  ): Promise<{ success: boolean; error?: string }> => {
    try {
      const { error } = await supabase
        .from('parent_eleve')
        .delete()
        .eq('parent_id', parentId)
        .eq('eleve_id', eleveId);

      if (error) throw error;
      return { success: true };
    } catch (error) {
      console.error('Error deleting parent-eleve link:', error);
      return { success: false, error: 'Impossible de supprimer le lien' };
    }
  }, []);

  return {
    loading,
    verifying,
    linking,
    verifierParent,
    confirmerParentParEnfant,
    creerNouveauParent,
    lierParent,
    getParentsDeLEleve,
    mettreAJourLien,
    supprimerLien,
  };
}